{
  "name": "xeno-ai-crm",
  "version": "1.0.0",
  "description": "AI-Native Mini CRM and Channel Service Callback Loop",
  "main": "dist/crm/server.js",
  "scripts": {
    "build": "tsc",
    "crm:dev": "ts-node src/crm/server.ts",
    "channel:dev": "ts-node src/channel/server.ts",
    "dev": "concurrently \"npm run crm:dev\" \"npm run channel:dev\"",
    "prisma:generate": "prisma generate",
    "prisma:db": "prisma db push",
    "seed": "ts-node src/seed.ts",
    "test-flow": "ts-node src/test-flow.ts",
    "start": "concurrently \"node dist/crm/server.js\" \"node dist/channel/server.js\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.13.0",
    "@prisma/client": "^5.15.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "prisma": "^5.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
